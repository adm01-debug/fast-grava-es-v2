# ============================================================================
# FAST GRAVA ES - VARIÁVEIS DE AMBIENTE
# ============================================================================
# Copie este arquivo para .env.local e preencha os valores reais

# Supabase (OBRIGATÓRIO)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PROJECT_ID=seu-project-id
# O client lê VITE_SUPABASE_PUBLISHABLE_KEY (chave publishable/anon)
VITE_SUPABASE_PUBLISHABLE_KEY=sua-publishable-key

# Bitrix24 (OBRIGATÓRIO para integrações)
VITE_BITRIX_WEBHOOK_URL=https://seu-dominio.bitrix24.com.br/rest/USER_ID/WEBHOOK_TOKEN

# Email (Resend)
VITE_RESEND_API_KEY=re_xxxx

# SMS/WhatsApp (Twilio)
VITE_TWILIO_ACCOUNT_SID=ACxxxx
VITE_TWILIO_AUTH_TOKEN=xxxx
VITE_TWILIO_PHONE_NUMBER=+1234567890
VITE_TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Ambiente
VITE_APP_ENV=development
VITE_APP_DEBUG=true

# Google (opcional)
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_ANALYTICS_ID=

# Sentry (opcional - monitoramento)
VITE_SENTRY_DSN=

# Webhook de alertas críticos (opcional)
VITE_ALERT_WEBHOOK_URL=
